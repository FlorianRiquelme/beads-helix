{
  "name": "beads-helix",
  "version": "0.1.0",
  "description": "Maturity-driven workflow layer on top of beads",
  "type": "module",
  "bin": {
    "helix": "./dist/cli.js"
  },
  "exports": {
    ".": "./dist/index.js",
    "./snapshot": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && vite build",
    "build:server": "tsc",
    "build:ui": "vite build",
    "dev": "concurrently -n api,ui -c cyan,magenta \"npm:dev:api\" \"npm:dev:ui\"",
    "dev:api": "tsx watch --clear-screen=false scripts/dev-server.ts",
    "dev:ui": "vite",
    "dev:tsc-watch": "tsc --watch",
    "lint": "tsc --noEmit && tsc -p web/tsconfig.json --noEmit",
    "pretest": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:mutate": "stryker run"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.14",
    "@radix-ui/react-dialog": "^1.1.15",
    "@tanstack/react-query": "^5.62.0",
    "@tanstack/react-router": "^1.114.0",
    "chokidar": "^5.0.0",
    "geist": "^1.3.1",
    "hono": "^4.12.12",
    "lucide-react": "^0.460.0",
    "mysql2": "^3.11.0",
    "proper-lockfile": "^4.1.2",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "rehype-sanitize": "^6.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^1.7.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/typescript-checker": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.6.0",
    "@testing-library/react": "^16.1.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/node": "^22.0.0",
    "@types/proper-lockfile": "^4.1.4",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "@vitest/coverage-v8": "^4.1.4",
    "concurrently": "^9.2.1",
    "jsdom": "^25.0.0",
    "tailwindcss": "^4.0.0",
    "tsx": "^4.21.0",
    "typescript": "^5.7.0",
    "vite": "^6.0.0",
    "vitest": "^4.1.4"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
